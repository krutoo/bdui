{
  "name": "bdui",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend-driven UI",
  "author": "Dmitriy Petrov <dima.krutoo@yandex.ru>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.14.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10.9.3",
      "onFail": "error"
    }
  },
  "scripts": {
    "fmt": "prettier --write .",
    "lint": "eslint --flag unstable_native_nodejs_ts_config .",
    "check": "tsc -p . --noEmit",
    "build": "node ./scripts/build.ts"
  },
  "devDependencies": {
    "@krutoo/presets": "^0.0.1",
    "@krutoo/utils": "^0.0.37",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.4",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": "./dist/mod.js"
  },
  "sideEffects": false
}
