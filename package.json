{
  "name": "@krutoo/bdui",
  "version": "0.0.0",
  "type": "module",
  "description": "Backend-driven UI",
  "author": "Dmitriy Petrov <dima.krutoo@yandex.ru>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.14.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10.9.3",
      "onFail": "error"
    }
  },
  "scripts": {
    "fmt": "prettier --write .",
    "lint": "eslint --flag unstable_native_nodejs_ts_config .",
    "check": "tsc -p . --noEmit",
    "test": "node --import @krutoo/ts-loader ./scripts/test.ts",
    "build": "node ./scripts/build.ts"
  },
  "devDependencies": {
    "@krutoo/presets": "^0.0.1",
    "@krutoo/ts-loader": "^0.0.4",
    "@krutoo/utils": "^0.0.37",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.4",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "tsc-alias": "^1.9.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/mod.js"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": "^19.2.7"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
